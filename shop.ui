  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string>
     QWidget {
        background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, 
                                    stop:0 #20b2aa, stop:1 #6a0dad);
        font-family: Arial, sans-serif;
     }
     QLabel#logo {
        font-size: 26px;
        font-weight: bold;
        color: white;
        background-color: #6a0dad;
        padding: 10px;
        border-radius: 10px;
     }
     QPushButton {
        background-color: #20b2aa;
        color: white;
        font-size: 14px;
        border-radius: 10px;
        padding: 8px;
        border: 2px solid white;
     }
     QPushButton:hover {
        background-color: #008b8b;
        border: 2px solid #ffffff;
     }
     QLineEdit {
        border: 2px solid white;
        border-radius: 10px;
        padding: 8px;
        background-color: rgba(255, 255, 255, 0.8);
        color: #333;
     }
     QScrollArea {
        border: none;
     }
     QLabel {
        color: white;
     }
     .product-card {
        background-color: #ffffff;
        border-radius: 10px;
        padding: 10px;
        margin: 10px;
        width: 250px;
        text-align: center;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
     }
     .product-card img {
        width: 100%;
        height: 150px;
        object-fit: contain;
     }
     .product-card .price {
        font-size: 18px;
        color: #008b8b;
        font-weight: bold;
     }
     .product-card .add-to-cart {
        margin-top: 10px;
        background-color: #20b2aa;
        color: white;
        font-size: 14px;
        border-radius: 10px;
        padding: 8px;
        border: 2px solid white;
     }
     .product-card .add-to-cart:hover {
        background-color: #008b8b;
        border: 2px solid #ffffff;
     }
    </string>
   </property>
